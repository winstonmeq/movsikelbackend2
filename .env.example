# --- Core (required) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
JWT_SECRET=replace-with-a-long-random-string

# --- Admin seed (used once by `npm run seed:admin`) ---
ADMIN_PHONE=09171234567
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_NAME=Site Admin

# --- Optional tuning ---
PER_KM_FARE_PHP=2
TRICYCLE_AVERAGE_KPH=20
DRIVER_SEARCH_RADIUS_METERS=1000
DRIVER_SEARCH_RADIUS_EXPANSION_METERS=500
DRIVER_SEARCH_MAX_RADIUS_METERS=2500
CORS_ORIGIN=*

# --- Firebase Admin (FCM push notifications) ---
# Paste the entire firebase-adminsdk.json content as a single-line JSON string
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# --- Staged sequential dispatch ---
DISPATCH_OFFER_WINDOW_MS=10000   # how long each driver/batch has to accept (ms)
DISPATCH_FIRST_BATCH=3           # first N drivers offered together, then 1-by-1
DRIVER_RESERVATION_GRACE_MS=1000 # keeps offered drivers reserved slightly past the offer window
