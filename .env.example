# --- Core (required) ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net
JWT_SECRET=replace-with-a-long-random-string

# --- Admin seed (used once by `npm run seed:admin`) ---
ADMIN_PHONE=09171234567
ADMIN_PASSWORD=change-this-to-a-strong-password
ADMIN_NAME=Site Admin

# --- Optional tuning ---
PER_KM_FARE_PHP=2
TRICYCLE_AVERAGE_KPH=20
DRIVER_SEARCH_RADIUS_METERS=15000
CORS_ORIGIN=*

# --- Google Places/Directions (server-side key; keep secret) ---
GOOGLE_MAPS_API_KEY=

# --- Dev/demo only ---
DUMMY_DRIVER_ENABLED=false
SHOW_ALL_OPEN_RIDES_TO_ONLINE_DRIVERS=true

# --- Staged sequential dispatch ---
DISPATCH_OFFER_WINDOW_MS=10000   # how long each driver/batch has to accept (ms)
DISPATCH_FIRST_BATCH=3           # first N drivers offered together, then 1-by-1
